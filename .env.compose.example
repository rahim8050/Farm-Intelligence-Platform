DJANGO_ENV=development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_SECRET_KEY=change-me-in-compose
DJANGO_API_KEY_PEPPER=change-me-long-random-string

DATABASE_URL=mysql://weather:weather@db:3306/weather_apis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

MYSQL_DATABASE=weather_apis
MYSQL_USER=weather
MYSQL_PASSWORD=weather
MYSQL_ROOT_PASSWORD=rootpassword

FRONTEND_RESET_URL=http://localhost:3000/reset-password
DEFAULT_FROM_EMAIL=no-reply@example.com
