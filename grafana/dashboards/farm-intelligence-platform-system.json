          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "refresh": 2
      },
      {
        "type": "query",
        "name": "instance",
        "label": "Node instance",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(up{job=\"node_exporter\"}, instance)",
