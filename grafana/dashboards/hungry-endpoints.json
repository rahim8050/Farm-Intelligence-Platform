  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Top 5 views by avg latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Shows the five Django views with the highest average request latency over 5m.",
      "targets": [
        {
          "expr": "topk(5, sum by (view,method) (increase(django_http_requests_latency_seconds_by_view_method_sum{job=\"django\"}[5m])) / sum by (view,method) (increase(django_http_requests_latency_seconds_by_view_method_count{job=\"django\"}[5m]))) and (sum by (view,method) (increase(django_http_requests_latency_seconds_by_view_method_count{job=\"django\"}[5m])) > 0)",
          "legendFormat": "{{view}}/{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        },
        "displayMode": "line"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request rate by view",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Requests per second per view so you can spot high-traffic endpoints.",
      "targets": [
        {
          "expr": "topk(5, sum by (view,method) (rate(django_http_requests_total_by_view_transport_method_total{job=\"django\"}[5m])))",
          "legendFormat": "{{view}}/{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
