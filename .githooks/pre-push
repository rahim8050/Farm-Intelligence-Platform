#!/usr/bin/env bash
set -euo pipefail

echo "=== Pre-push quick checks (ruff lint + format) ==="
cd "$(git rev-parse --show-toplevel)"

changed_py=$(git diff --name-only @{upstream}..HEAD -- '*.py' | sort -u || true)
if [ -z "$changed_py" ]; then
    echo "(no Python files changed in pushed commits)"
else
    UV_PROJECT_ENVIRONMENT=/tmp/fip-venv uv run ruff check $changed_py
    UV_PROJECT_ENVIRONMENT=/tmp/fip-venv uv run ruff format --check $changed_py
fi

echo "=== Quick checks passed ==="
echo "Run 'bash scripts/run-ci.sh' for full CI (mypy, bandit, Django checks, tests)."
