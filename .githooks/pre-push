#!/usr/bin/env bash
set -euo pipefail

echo "=== Pre-push quick checks (ruff lint + format) ==="
cd "$(git rev-parse --show-toplevel)"

if [ -f .venv/bin/python ]; then
    PY=.venv/bin/python
elif command -v python3 &>/dev/null; then
    PY=python3
else
    PY=python
fi

"$PY" -m ruff check .
"$PY" -m ruff format --check .

echo "=== Quick checks passed ==="
echo "Run 'bash scripts/run-ci.sh' for full CI (mypy, bandit, Django checks, tests)."
